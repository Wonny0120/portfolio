        "    preds = model.predict(X_v)\n",
        "    mae   = mean_absolute_error(y_v, preds)\n",
        "    rmse  = mean_squared_error(y_v, preds) ** 0.5\n",
        "    r2    = r2_score(y_v, preds)\n",
        "    print(f\"  {name:<30s}  MAE={mae:7.2f}  RMSE={rmse:7.2f}  R²={r2:.4f}\")\n",
        "    return model, preds\n",
        "\n",
